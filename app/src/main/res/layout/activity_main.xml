<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:keepScreenOn="true">

    <!-- зӣёжңәйў„и§Ҳ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- и®ҫеӨҮзҠ¶жҖ?-->
        <TextView
            android:id="@+id/tvDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="#CC000000"
            android:padding="8dp"
            android:text="жңӘеҸ‘зҺ°и®ҫеӨ?
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <!-- з…§зүҮи®Ўж•° -->
        <TextView
            android:id="@+id/tvPhotoCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:layout_marginBottom="80dp"
            android:background="#CC000000"
            android:padding="8dp"
            android:text="0 еј еҫ…дј?
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </FrameLayout>

    <!-- еӯ—ж®өзј–иҫ‘еҢәпјҲеҸҜжҠҳеҸ пјү -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/etProjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="йЎ№зӣ®еҗҚз§°"
                android:textSize="14sp"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etConstructionUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="ж–Ҫе·ҘеҚ•дҪҚ"
                    android:textSize="14sp"
                    android:singleLine="true" />

                <EditText
                    android:id="@+id/etConstructionArea"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="ж–Ҫе·ҘеҢәеҹҹ"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etConstructionContent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:hint="ж–Ҫе·ҘеҶ…е®№"
                    android:textSize="14sp"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnTemplates"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="жЁЎжқҝ"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="иҮӘеҠЁдёҠдј "
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/switchAutoUpload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btnGallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="зӣёеҶҢ"
                    android:textSize="12sp"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- еҝ«й—ЁжҢүй’® -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#222222">

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_shutter"
            android:text=""
            android:elevation="4dp" />

    </FrameLayout>

</LinearLayout>
